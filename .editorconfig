# See https://editorconfig.org for more info

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{json,yml,yaml}]
indent_size = 2

[*.{vue,js,ts,jsx,tsx}]
indent_size = 2

[*.vue]
indent_size = 2

[Makefile]
indent_style = tab

[*.py]
indent_size = 4
