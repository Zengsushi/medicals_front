{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "set LANG=zh_CN.UTF-8 && vite",
    "build": "set LANG=zh_CN.UTF-8 && vite build",
    "preview": "set LANG=zh_CN.UTF-8 && vite preview",
    "build:analyze": "set LANG=zh_CN.UTF-8 && vite build --mode analyze",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix --ignore-path .gitignore",
    "lint:check": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --ignore-path .gitignore",
    "format": "prettier --write \"src/**/*.{js,ts,vue,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,css,md}\""
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@surely-vue/table": "^5.0.13",
    "@vueuse/core": "^14.2.1",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.12.2",
    "echarts": "^6.0.0",
    "lodash": "^4.17.23",
    "pinia": "^3.0.4",
    "router": "^2.2.0",
    "vue": "^3.5.22",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-vue": "^9.27.0",
    "less": "^4.4.2",
    "prettier": "^3.3.3",
    "rollup-plugin-visualizer": "^5.9.3",
    "sass-embedded": "^1.99.0",
    "terser": "^5.46.1",
    "vite": "^7.1.7"
  }
}
