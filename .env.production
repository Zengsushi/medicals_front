# 生产环境配置
NODE_ENV=production

# API 基础url（生产环境使用相对路径，通过nginx代理）
VITE_API_BASE_URL=/api

# API 超时时间（毫秒）
VITE_API_TIMEOUT=20000

# 应用信息
VUE_APP_TITLE=医疗数据分析系统
VUE_APP_VERSION=1.0.0
VUE_APP_DESCRIPTION=基于Hive - Spark的医疗数据分析系统

# 生产环境关闭调试
VUE_APP_DEBUG=false

# 性能优化开关
VITE_ENABLE_GZIP=true
VITE_ENABLE_BROTLI=true
VITE_ENABLE_CDN=false

# 安全相关
VITE_ENABLE_CSP=true
VITE_ENABLE_PWA=false
